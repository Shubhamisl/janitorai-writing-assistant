{
  "manifest_version": 3,
  "name": "JanitorAI Writing Assistant",
  "version": "1.0.0",
  "description": "AI-powered writing enhancements for roleplay and storytelling.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "host_permissions": [
    "*://janitorai.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://janitorai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "sidebar_action": {
    "default_title": "Writing Assistant",
    "default_panel": "sidebar/sidebar.html",
    "default_icon": "icons/icon-48.png"
  },
  "action": {
    "default_icon": "icons/icon-48.png",
    "default_title": "Writing Assistant Settings",
    "default_popup": "popup/popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "janitorai-writer@example.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}